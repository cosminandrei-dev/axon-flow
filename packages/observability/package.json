{
  "name": "@repo/observability",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./logger": {
      "types": "./dist/src/logger.d.ts",
      "import": "./dist/src/logger.js"
    },
    "./tracer": {
      "types": "./dist/src/tracer.d.ts",
      "import": "./dist/src/tracer.js"
    },
    "./metrics": {
      "types": "./dist/src/metrics.d.ts",
      "import": "./dist/src/metrics.js"
    },
    "./middleware": {
      "types": "./dist/src/middleware/correlation.d.ts",
      "import": "./dist/src/middleware/correlation.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pino": "^9.6.0",
    "@opentelemetry/sdk-node": "^0.200.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.200.0",
    "@opentelemetry/instrumentation-http": "^0.200.0",
    "@opentelemetry/instrumentation-pg": "^0.51.0",
    "@opentelemetry/instrumentation-graphql": "^0.56.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.32.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.8",
    "pino-pretty": "^13.0.0",
    "vitest": "^4.0.14",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*"
  }
}
