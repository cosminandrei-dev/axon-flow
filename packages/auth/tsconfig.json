{
  "extends": "../../tooling/typescript/library.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@repo/*": ["../../packages/*/src"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*", "*.config.ts", "__tests__/**/*"],
  "exclude": ["node_modules", "dist"]
}
