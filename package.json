{
  "name": "axon-flow",
  "version": "0.0.0",
  "private": true,
  "description": "Hub-centric AI automation platform that transforms natural-language goals into reliable, observable, multi-agent workflows",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "docker:up": "docker compose -f docker/docker-compose.yml --env-file docker/.env.local up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:reset": "docker compose -f docker/docker-compose.yml down -v && docker compose -f docker/docker-compose.yml --env-file docker/.env.local up -d",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "db:generate": "pnpm --filter @repo/database db:generate",
    "db:migrate": "pnpm --filter @repo/database db:migrate",
    "db:studio": "pnpm --filter @repo/database db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "turbo": "^2.6.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
